    private void btnPrintActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_btnPrintActionPerformed
        try {

    JFileChooser chooser = new JFileChooser();
    chooser.setDialogTitle("Simpan PDF");

    int hasil = chooser.showSaveDialog(this);

    if (hasil == JFileChooser.APPROVE_OPTION) {

        String lokasi = chooser.getSelectedFile().getAbsolutePath();

        if (!lokasi.endsWith(".pdf")) {
            lokasi += ".pdf";
        }

        Document document = new Document();

        PdfWriter.getInstance(document, new FileOutputStream(lokasi));

        document.open();

        document.add(new Paragraph("RIWAYAT TRANSAKSI COFFEE SHOP"));
        document.add(new Paragraph(" "));
        
        PdfPTable pdfTable = new PdfPTable(tblRiwayat.getColumnCount());

        // Header
        for (int i = 0; i < tblRiwayat.getColumnCount(); i++) {
            pdfTable.addCell(tblRiwayat.getColumnName(i));
        }

        // Isi tabel
        for (int rows = 0; rows < tblRiwayat.getRowCount(); rows++) {
            for (int cols = 0; cols < tblRiwayat.getColumnCount(); cols++) {

                Object data = tblRiwayat.getValueAt(rows, cols);

                pdfTable.addCell(data == null ? "" : data.toString());

            }
        }

        document.add(pdfTable);

        document.close();

        JOptionPane.showMessageDialog(this,
                "PDF berhasil disimpan di:\n" + lokasi);

    }

} catch (Exception e) {

    JOptionPane.showMessageDialog(this, e);

}
  

    }//GEN-LAST:event_btnPrintActionPerformed

